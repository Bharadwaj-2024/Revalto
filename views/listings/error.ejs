<% layout('layouts/boilerplate') %>

<div class="row">
    <div class="col-md-8 offset-md-2 text-center">
        <div class="error-container py-5">
            <div class="error-icon mb-4">
                <i class="fas fa-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
            </div>
            <h1 class="display-1 text-danger fw-bold mb-2"><%= statusCode || 500 %></h1>
            <h3 class="mb-4">Something Went Wrong</h3>
            <p class="lead text-muted mb-4"><%= message %></p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/listings" class="btn btn-primary btn-lg">
                    <i class="fas fa-home me-2"></i>Back to Properties
                </a>
                <button onclick="history.back()" class="btn btn-outline-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i>Go Back
                </button>
            </div>
        </div>
    </div>
</div>
