<% layout('layouts/boilerplate') %>

<!-- Hero Section -->
<div class="about-hero text-center mb-5">
    <h1 class="display-4 fw-bold">About Revalto</h1>
    <p class="lead text-muted">Your Trusted Partner in Real Estate</p>
</div>

<!-- Who We Are -->
<div class="row mb-5">
    <div class="col-lg-6 mb-4 mb-lg-0">
        <div class="about-card h-100">
            <div class="about-icon">
                <i class="fas fa-building"></i>
            </div>
            <h3>Who We Are</h3>
            <p><strong>Revalto Pvt. Limited</strong> is a leading real estate platform dedicated to transforming how people buy, sell, and discover properties. Founded with a vision to simplify real estate transactions, we connect property seekers with their dream homes and help sellers reach the right buyers.</p>
            <p>With years of experience in the Indian real estate market, our team of experts understands the challenges faced by both buyers and sellers. We leverage technology and market insights to provide a seamless property experience.</p>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="about-card h-100">
            <div class="about-icon">
                <i class="fas fa-bullseye"></i>
            </div>
            <h3>Our Mission</h3>
            <p>To make real estate transactions <strong>transparent, simple, and accessible</strong> for everyone. We believe that finding the perfect property shouldn't be stressful or complicated.</p>
            <p>We aim to bridge the gap between property owners and seekers by providing a reliable platform where trust and convenience come first.</p>
        </div>
    </div>
</div>

<!-- Problem We Solve -->
<div class="problem-section mb-5">
    <h2 class="text-center mb-4"><i class="fas fa-lightbulb me-2"></i>The Problem We Solve</h2>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="problem-card">
                <div class="problem-icon bg-danger">
                    <i class="fas fa-search"></i>
                </div>
                <h5>Difficult Property Search</h5>
                <p>Finding the right property often involves visiting multiple agents, browsing countless websites, and dealing with outdated listings. We centralize all properties in one platform with accurate, up-to-date information.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="problem-card">
                <div class="problem-icon bg-warning">
                    <i class="fas fa-user-secret"></i>
                </div>
                <h5>Lack of Transparency</h5>
                <p>Hidden fees, misleading property details, and unclear pricing create distrust. At Revalto, every listing shows clear pricing, accurate descriptions, and verified information.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="problem-card">
                <div class="problem-icon bg-info">
                    <i class="fas fa-handshake-slash"></i>
                </div>
                <h5>Trust Issues</h5>
                <p>Many buyers and sellers face fraud or unprofessional behavior. We provide a secure platform where transactions happen safely with verified users and properties.</p>
            </div>
        </div>
    </div>
</div>

<!-- How We Do It -->
<div class="solution-section mb-5">
    <h2 class="text-center mb-4"><i class="fas fa-cogs me-2"></i>How We Do Business</h2>
    <div class="row align-items-center">
        <div class="col-lg-6">
            <div class="solution-list">
                <div class="solution-item">
                    <span class="solution-number">1</span>
                    <div>
                        <h5>Verified Listings</h5>
                        <p>Every property on our platform goes through a verification process to ensure accuracy and authenticity.</p>
                    </div>
                </div>
                <div class="solution-item">
                    <span class="solution-number">2</span>
                    <div>
                        <h5>Direct Connection</h5>
                        <p>We connect buyers directly with sellers, eliminating unnecessary middlemen and reducing costs.</p>
                    </div>
                </div>
                <div class="solution-item">
                    <span class="solution-number">3</span>
                    <div>
                        <h5>Expert Support</h5>
                        <p>Our team of real estate experts is always available to guide you through every step of the process.</p>
                    </div>
                </div>
                <div class="solution-item">
                    <span class="solution-number">4</span>
                    <div>
                        <h5>Secure Transactions</h5>
                        <p>We ensure all transactions are conducted securely with proper documentation and legal compliance.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="stats-grid">
                <div class="stat-card">
                    <h2 class="stat-number">500+</h2>
                    <p>Properties Listed</p>
                </div>
                <div class="stat-card">
                    <h2 class="stat-number">1000+</h2>
                    <p>Happy Customers</p>
                </div>
                <div class="stat-card">
                    <h2 class="stat-number">50+</h2>
                    <p>Cities Covered</p>
                </div>
                <div class="stat-card">
                    <h2 class="stat-number">24/7</h2>
                    <p>Customer Support</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Why Choose Us -->
<div class="why-choose-section mb-5">
    <h2 class="text-center mb-4"><i class="fas fa-star me-2"></i>Why Choose Revalto?</h2>
    <div class="row">
        <div class="col-md-3 col-6 mb-4">
            <div class="feature-box text-center">
                <i class="fas fa-check-circle"></i>
                <h6>100% Verified</h6>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <div class="feature-box text-center">
                <i class="fas fa-rupee-sign"></i>
                <h6>Best Prices</h6>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <div class="feature-box text-center">
                <i class="fas fa-lock"></i>
                <h6>Secure Deals</h6>
            </div>
        </div>
        <div class="col-md-3 col-6 mb-4">
            <div class="feature-box text-center">
                <i class="fas fa-headset"></i>
                <h6>Expert Support</h6>
            </div>
        </div>
    </div>
</div>

<!-- CTA Section -->
<div class="cta-section text-center">
    <h3>Ready to Find Your Dream Property?</h3>
    <p class="text-muted mb-4">Browse through our extensive collection of properties or list your own.</p>
    <a href="/listings" class="btn btn-primary btn-lg me-3">
        <i class="fas fa-search me-2"></i>Browse Properties
    </a>
    <a href="/listings/new" class="btn btn-outline-primary btn-lg">
        <i class="fas fa-plus me-2"></i>List Your Property
    </a>
</div>