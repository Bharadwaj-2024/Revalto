<% layout('layouts/boilerplate') %>

<div class="row">
    <!-- Property Details -->
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <% if(listing.image && listing.image.url) { %>
                <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="card-img-top property-detail-image">
            <% } %>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h2 class="card-title mb-0"><%= listing.title %></h2>
                    <% if (listing.status === 'sold') { %>
                        <span class="badge bg-danger fs-6">SOLD</span>
                    <% } else if (listing.status === 'under-offer') { %>
                        <span class="badge bg-warning text-dark fs-6">Under Offer</span>
                    <% } else { %>
                        <span class="badge bg-success fs-6">Available</span>
                    <% } %>
                </div>
                
                <p class="card-text"><%= listing.description %></p>
                
                <hr>
                
                <p class="mb-2">
                    <i class="fas fa-rupee-sign me-2"></i>
                    <strong>Price:</strong> ₹<%= listing.price.toLocaleString("en-IN") %>
                </p>
                <p class="mb-2">
                    <i class="fas fa-map-marker-alt me-2"></i>
                    <strong>Location:</strong> <%= listing.location %>, <%= listing.country %>
                </p>

                <% if (listing.category) { %>
                <p class="mb-2">
                    <i class="fas fa-tag me-2"></i>
                    <strong>Type:</strong>
                    <span class="badge bg-warning text-dark">
                        <%= listing.category.charAt(0).toUpperCase() + listing.category.slice(1).replace('-', '/') %>
                    </span>
                </p>
                <% } %>
                
                <hr>
                
                <% if (listing.owner) { %>
                <p class="mb-2">
                    <i class="fas fa-user me-2"></i>
                    <strong>Owner:</strong> <%= listing.owner.username %>
                </p>
                <% } %>

                <div class="d-flex gap-2 flex-wrap">
                    <% if (currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
                        <i class="fas fa-edit me-1"></i>Edit
                    </a>
                    <form action="/listings/<%= listing._id %>?_method=DELETE" method="post" class="d-inline">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this property?')">
                            <i class="fas fa-trash me-1"></i>Delete
                        </button>
                    </form>
                    <% } %>
                    <a href="/listings" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Listings
                    </a>
                </div>
            </div>
        </div>

        <!-- ==================== PROPERTY LOCATION MAP ==================== -->
        <div class="map-section mt-5">
            <h4 class="section-heading">
                <i class="fas fa-map-marked-alt me-2"></i>Property Location
            </h4>
            <div id="show-map" class="listing-map"></div>
            <p class="text-muted mt-2">
                <i class="fas fa-map-marker-alt me-1"></i>
                <%= listing.location %>, <%= listing.country %>
            </p>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const coords = <%= JSON.stringify(listing.geometry ? listing.geometry.coordinates : [0, 0]) %>;
                const lng = coords[0];
                const lat = coords[1];

                // Only show map if we have real coordinates
                if (lat !== 0 || lng !== 0) {
                    const map = L.map('show-map').setView([lat, lng], 15);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        maxZoom: 19,
                        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                    }).addTo(map);

                    const marker = L.marker([lat, lng]).addTo(map);
                    marker.bindPopup(
                        `<strong><%= listing.title %></strong><br><%= listing.location %>, <%= listing.country %><br>₹<%= listing.price.toLocaleString("en-IN") %>`
                    ).openPopup();

                    // Fix tile rendering when map container was hidden/resized
                    setTimeout(function() { map.invalidateSize(); }, 200);
                } else {
                    document.getElementById('show-map').innerHTML = '<div class="text-center text-muted py-5"><i class="fas fa-map fa-3x mb-3"></i><p>Map not available for this location.</p></div>';
                }
            });
        </script>

        <!-- ==================== PROPERTY DOCUMENTS SECTION ==================== -->
        <div class="documents-section mt-5">
            <h4 class="section-heading">
                <i class="fas fa-file-alt me-2"></i>Property Documents
                <% if (listing.documents) { %>
                    <span class="badge bg-info ms-2"><%= listing.documents.length %></span>
                <% } %>
            </h4>
            <p class="text-muted mb-3">
                <i class="fas fa-shield-alt me-1"></i>
                Verified documents help buyers feel safe and confident about the property.
            </p>

            <!-- Existing Documents -->
            <% if (listing.documents && listing.documents.length > 0) { %>
                <div class="row">
                    <% for (let doc of listing.documents) { %>
                    <div class="col-md-6 mb-3">
                        <div class="card document-card">
                            <div class="card-body d-flex align-items-center">
                                <div class="doc-icon me-3">
                                    <% if (doc.docType === 'title-deed') { %>
                                        <i class="fas fa-file-contract fa-2x text-primary"></i>
                                    <% } else if (doc.docType === 'sale-agreement') { %>
                                        <i class="fas fa-file-signature fa-2x text-success"></i>
                                    <% } else if (doc.docType === 'property-tax-receipt') { %>
                                        <i class="fas fa-receipt fa-2x text-warning"></i>
                                    <% } else if (doc.docType === 'building-approval') { %>
                                        <i class="fas fa-building fa-2x text-info"></i>
                                    <% } else { %>
                                        <i class="fas fa-file fa-2x text-secondary"></i>
                                    <% } %>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1"><%= doc.name %></h6>
                                    <small class="text-muted text-capitalize"><%= doc.docType.replace(/-/g, ' ') %></small>
                                    <br>
                                    <small class="text-muted">
                                        <i class="far fa-clock me-1"></i>
                                        <%= new Date(doc.uploadedAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                    </small>
                                </div>
                                <div class="ms-2">
                                    <a href="<%= doc.file.url %>" target="_blank" class="btn btn-sm btn-outline-primary me-1" title="View Document">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <% if (currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
                                        <form action="/listings/<%= listing._id %>/documents/<%= doc._id %>?_method=DELETE" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Document" onclick="return confirm('Delete this document?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
            <% } else { %>
                <div class="empty-state-card mb-3">
                    <i class="far fa-folder-open fa-2x mb-2 text-muted"></i>
                    <p class="text-muted mb-0">No documents uploaded yet.</p>
                </div>
            <% } %>

            <!-- Upload Document Form (Owner Only) -->
            <% if (currentUser && listing.owner && listing.owner._id.equals(currentUser._id)) { %>
                <div class="card mt-3 upload-doc-card">
                    <div class="card-body">
                        <h5 class="mb-3"><i class="fas fa-upload me-2"></i>Upload Property Document</h5>
                        <form action="/listings/<%= listing._id %>/documents" method="POST" enctype="multipart/form-data">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="docName" class="form-label">Document Name</label>
                                    <input type="text" class="form-control" id="docName" name="name" placeholder="e.g., Title Deed" required>
                                </div>
                                <div class="col-md-4">
                                    <label for="docType" class="form-label">Document Type</label>
                                    <select class="form-select" id="docType" name="docType" required>
                                        <option value="title-deed">Title Deed</option>
                                        <option value="sale-agreement">Sale Agreement</option>
                                        <option value="encumbrance-certificate">Encumbrance Certificate</option>
                                        <option value="property-tax-receipt">Property Tax Receipt</option>
                                        <option value="building-approval">Building Approval</option>
                                        <option value="occupancy-certificate">Occupancy Certificate</option>
                                        <option value="noc">NOC</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="document" class="form-label">File</label>
                                    <input type="file" class="form-control" id="document" name="document" required accept=".pdf,.jpg,.jpeg,.png,.webp">
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary mt-3">
                                <i class="fas fa-cloud-upload-alt me-1"></i>Upload Document
                            </button>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- ==================== BUY / MAKE OFFER SECTION ==================== -->
        <% if (currentUser && listing.owner && !listing.owner._id.equals(currentUser._id) && listing.status !== 'sold') { %>
        <div class="buy-section mt-5">
            <div class="card buy-card border-success">
                <div class="card-body">
                    <h4 class="card-title text-success mb-3">
                        <i class="fas fa-shopping-cart me-2"></i>Buy This Property
                    </h4>

                    <% if (existingOffer) { %>
                        <!-- Show existing offer status -->
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>You have an active offer on this property.</strong>
                            <br>
                            <span>Offer Amount: ₹<%= existingOffer.offerPrice.toLocaleString('en-IN') %></span> &mdash;
                            <span>Status: 
                                <% if (existingOffer.status === 'pending') { %>
                                    <span class="badge bg-warning text-dark">Pending</span>
                                <% } else if (existingOffer.status === 'accepted') { %>
                                    <span class="badge bg-success">Accepted</span>
                                <% } %>
                            </span>
                            <br>
                            <a href="/purchases" class="btn btn-sm btn-outline-primary mt-2">
                                <i class="fas fa-eye me-1"></i>View My Offers
                            </a>
                        </div>
                    <% } else { %>
                        <p class="text-muted">Make a purchase offer to the property owner. They will review and respond to your offer.</p>
                        
                        <form action="/purchases/listing/<%= listing._id %>" method="POST">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="offerPrice" class="form-label fw-semibold">Your Offer Price (₹)</label>
                                    <input type="number" class="form-control" id="offerPrice" name="offerPrice" 
                                        value="<%= listing.price %>" min="1" required>
                                    <small class="text-muted">Asking price: ₹<%= listing.price.toLocaleString('en-IN') %></small>
                                </div>
                                <div class="col-md-6">
                                    <label for="buyerPhone" class="form-label fw-semibold">Your Phone Number</label>
                                    <input type="tel" class="form-control" id="buyerPhone" name="phone" 
                                        placeholder="e.g., +91 98765 43210" required>
                                </div>
                                <div class="col-12">
                                    <label for="buyerMessage" class="form-label fw-semibold">Message to Owner (Optional)</label>
                                    <textarea class="form-control" id="buyerMessage" name="message" rows="3" 
                                        placeholder="Tell the owner why you're interested in this property..."></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-success btn-lg mt-3" onclick="return confirm('Send this purchase offer?')">
                                <i class="fas fa-paper-plane me-2"></i>Send Purchase Offer
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>

        <!-- ==================== BOOK A MEETING SECTION ==================== -->
        <% if (currentUser && listing.owner && !listing.owner._id.equals(currentUser._id)) { %>
        <div class="booking-section mt-5">
            <div class="card booking-card border-primary">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-3">
                        <i class="fas fa-calendar-check me-2"></i>Book a Meeting with Owner
                    </h4>

                    <% if (existingBooking) { %>
                        <!-- Show existing booking status -->
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>You have an active meeting request for this property.</strong>
                            <br>
                            <span>Date: <%= new Date(existingBooking.meetingDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %></span> &mdash;
                            <span>Time: <%= existingBooking.meetingTime %></span> &mdash;
                            <span>Status: 
                                <% if (existingBooking.status === 'pending') { %>
                                    <span class="badge bg-warning text-dark">Pending</span>
                                <% } else if (existingBooking.status === 'confirmed') { %>
                                    <span class="badge bg-success">Confirmed</span>
                                <% } %>
                            </span>
                            <br>
                            <a href="/bookings" class="btn btn-sm btn-outline-primary mt-2">
                                <i class="fas fa-eye me-1"></i>View My Meetings
                            </a>
                        </div>
                    <% } else { %>
                        <p class="text-muted">Schedule a meeting with the property owner to discuss and inspect the property.</p>
                        
                        <form action="/bookings/listing/<%= listing._id %>" method="POST">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="meetingDate" class="form-label fw-semibold">Meeting Date</label>
                                    <input type="date" class="form-control" id="meetingDate" name="meetingDate" 
                                        min="<%= new Date().toISOString().split('T')[0] %>" required>
                                </div>
                                <div class="col-md-4">
                                    <label for="meetingTime" class="form-label fw-semibold">Meeting Time</label>
                                    <input type="time" class="form-control" id="meetingTime" name="meetingTime" required>
                                </div>
                                <div class="col-md-4">
                                    <label for="meetingType" class="form-label fw-semibold">Meeting Type</label>
                                    <select class="form-select" id="meetingType" name="meetingType" required>
                                        <option value="in-person">In Person</option>
                                        <option value="video-call">Video Call</option>
                                        <option value="phone-call">Phone Call</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="meetingPhone" class="form-label fw-semibold">Your Phone Number</label>
                                    <input type="tel" class="form-control" id="meetingPhone" name="phone" 
                                        placeholder="e.g., +91 98765 43210" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="meetingMessage" class="form-label fw-semibold">Message (Optional)</label>
                                    <textarea class="form-control" id="meetingMessage" name="message" rows="2" 
                                        placeholder="Any specific questions or requirements..."></textarea>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg mt-3">
                                <i class="fas fa-calendar-plus me-2"></i>Request Meeting
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>

        <!-- ==================== REVIEWS SECTION ==================== -->
        <% if (currentUser) { %>
        <div class="review-section mt-5">
            <div class="review-form-card">
                <h4 class="review-section-title">
                    <i class="fas fa-pen-fancy me-2"></i>Leave a Review
                </h4>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" class="review-form">
                    
                    <!-- Star Rating -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Your Rating</label>
                        <fieldset class="starability-slot">
                            <input type="radio" id="rate5" name="review[rating]" value="5" checked />
                            <label for="rate5" title="Amazing">5 stars</label>
                            <input type="radio" id="rate4" name="review[rating]" value="4" />
                            <label for="rate4" title="Very good">4 stars</label>
                            <input type="radio" id="rate3" name="review[rating]" value="3" />
                            <label for="rate3" title="Average">3 stars</label>
                            <input type="radio" id="rate2" name="review[rating]" value="2" />
                            <label for="rate2" title="Not good">2 stars</label>
                            <input type="radio" id="rate1" name="review[rating]" value="1" />
                            <label for="rate1" title="Terrible">1 star</label>
                        </fieldset>
                    </div>

                    <!-- Comment -->
                    <div class="mb-4">
                        <label for="comment" class="form-label fw-semibold">Your Comment</label>
                        <textarea class="form-control review-textarea" name="review[comment]" id="comment" rows="4" placeholder="Share your experience about this property..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-submit-review">
                        <i class="fas fa-paper-plane me-2"></i>Submit Review
                    </button>
                </form>
            </div>
        </div>
        <% } %>

        <!-- All Reviews Section -->
        <div class="reviews-list mt-5 mb-5">
            <h4 class="review-section-title">
                <i class="fas fa-comments me-2"></i>Reviews
                <span class="review-count-badge"><%= listing.reviews.length %></span>
            </h4>

            <% if(listing.reviews.length === 0) { %>
                <div class="no-reviews-card">
                    <i class="far fa-comment-dots"></i>
                    <h5>No Reviews Yet</h5>
                    <p>Be the first to share your thoughts about this property!</p>
                </div>
            <% } else { %>
                <% for(let review of listing.reviews) { %>
                    <div class="review-card">
                        <div class="review-card-header">
                            <div class="reviewer-avatar">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="reviewer-info">
                                <span class="reviewer-name"><%= review.author ? review.author.username : 'Guest Reviewer' %></span>
                                <span class="review-date">
                                    <i class="far fa-calendar-alt me-1"></i>
                                    <%= new Date(review.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </span>
                            </div>
                            <% if (currentUser && review.author && review.author._id.equals(currentUser._id)) { %>
                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="ms-auto">
                                <button type="submit" class="btn btn-delete-review" title="Delete Review" onclick="return confirm('Delete this review?')">
                                    <i class="fas fa-times"></i>
                                </button>
                            </form>
                            <% } %>
                        </div>
                        <div class="review-stars">
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= review.rating) { %>
                                    <i class="fas fa-star"></i>
                                <% } else { %>
                                    <i class="far fa-star"></i>
                                <% } %>
                            <% } %>
                            <span class="rating-text"><%= review.rating %>/5</span>
                        </div>
                        <p class="review-comment"><%= review.comment %></p>
                    </div>
                <% } %>
            <% } %>
        </div>

    </div>
</div>